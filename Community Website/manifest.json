{
  "manifest_version": 3,
  "name": "XCLUB CLICKER",
  "version": "2.0.0",
  "description": "Membantu membuka inbox distribusi XCashShop dan menekan tombol Setuju secara otomatis untuk item yang masih menunggu.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://xcashshop.club/*"
  ],
  "action": {
    "default_title": "DarkSystem Auto Approver",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://xcashshop.club/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
